# Flutter uses --dart-define rather than runtime .env loading.
# Keep these values aligned with the NestJS backend and deployment setup.

API_BASE_URL=http://127.0.0.1:3000
DEBUG_SHARED_API_BASE_URL=
LOCAL_LAN_API_BASE_URL=
LOCAL_ANDROID_DEBUG_API_BASE_URL=http://10.0.2.2:3000
SOCKET_BASE_URL=
SOCKET_PATH=/socket
SOCKET_CONTRACT_PATH=/socket/contract
ALLOW_OFFLINE_FALLBACK=false
APP_FLAVOR=dev
